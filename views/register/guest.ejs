<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <script src="/js/eventListeners.js" defer></script>
    <title>Register | filmsnerds</title>
  </head>
  <body>
    <%- include("../partials/header") %>
    <main>
      <form action="/register/guest" method="post">
        <h2>Create an Account</h2>
        <%- include("../partials/errors") %>
        <label for="username"
          >Username<input
            type="text"
            name="username"
            id="username"
            value="<%= locals.values?.username %>"
            required
        /></label>
        <label for="password">
          <div class="password-label-show-container">
            Password
            <span class="show-password-button unselectable">Show</span>
          </div>
          <div class="password-input-line">
            <input
              type="password"
              name="password"
              id="password"
              value="<%= locals.values?.password %>"
              required
            />
          </div>
        </label>
        <label for="confirm-password">
          Confirm password
          <div class="password-input-line">
            <input
              type="password"
              name="confirm-password"
              id="confirm-password"
              value="<%= locals.values?.['confirm-password'] %>"
              required
            />
          </div>
        </label>
        <div class="buttons">
          <button type="submit">Submit</button>
          <button id="demo-password-button">Fill Demo Password</button>
        </div>
      </form>
    </main>
  </body>
</html>
