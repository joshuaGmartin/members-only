<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/style.css" />
    <title>New Message | filmsnerds</title>
  </head>
  <body>
    <%- include("../partials/header") %>

    <main>
      <form action="/member/new-message" method="post" id="new-message-form">
        <h2>Create a Message</h2>
        <%- include("../partials/errors") %>
        <label for="title"
          >Title<input
            type="text"
            name="title"
            id="title"
            value="<%= locals.values?.title %>"
            required
        /></label>
        <label for="text"
          >Message
          <!-- can't leave any space in textarea -->
          <textarea name="text" id="text" required>
<%= locals.values?.text %></textarea
          >
        </label>

        <button type="submit">Submit</button>
      </form>
    </main>
  </body>
</html>
